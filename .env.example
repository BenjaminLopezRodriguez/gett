# Copy to .env and fill in values.
# Run builds without all vars: SKIP_ENV_VALIDATION=true pnpm run build

# Database (required)
DATABASE_URL="postgresql://postgres:password@localhost:5432/gett"

# Kinde Auth — https://kinde.com/docs/developer-tools/sdks/backend/nextjs-sdk/
KINDE_CLIENT_ID=""
KINDE_CLIENT_SECRET=""
KINDE_ISSUER_URL="https://your-subdomain.kinde.com"
KINDE_SITE_URL="http://localhost:3000"
KINDE_POST_LOGOUT_REDIRECT_URL="http://localhost:3000"
KINDE_POST_LOGIN_REDIRECT_URL="http://localhost:3000/dashboard"

# Anthropic / Claude (LangChain agents)
ANTHROPIC_API_KEY=""

# pdf.ai — document extraction
PDF_AI_API_KEY=""
# PDF_AI_BASE_URL="https://api.pdf.ai"

# Cloudflare R2 — document storage (S3-compatible)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET_CASES="gett-cases"
R2_BUCKET_LEGAL_CORPUS="legalcorpus"
# R2_PUBLIC_URL="https://pub-<hash>.r2.dev"

# Chat SDK — Slack intake bot (optional scaffold)
SLACK_BOT_TOKEN=""
SLACK_SIGNING_SECRET=""
CHAT_WEBHOOK_SECRET=""
